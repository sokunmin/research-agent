TAVILY_API_KEY=
OPENALEX_API_KEY=
OPENALEX_EMAIL=

# LiteLLM model IDs — change values here to switch providers, no code changes needed
LLM_SMART_MODEL=gemini/gemini-2.5-flash
LLM_FAST_MODEL=gemini/gemini-2.5-flash
LLM_VISION_MODEL=gemini/gemini-2.5-flash
LLM_EMBED_MODEL=gemini/gemini-embedding-001

# Provider API keys — set whichever provider you use
GEMINI_API_KEY=          # get free key at aistudio.google.com
OPENROUTER_API_KEY=      # openrouter.ai — 50 free req/day
MISTRAL_API_KEY=         # console.mistral.ai

# Azure OpenAI — optional; VLM still needs it until Phase 4
# To use Azure for LLM: set LLM_SMART_MODEL=azure/gpt-4o + these fields
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_GPT4O_MODEL=
AZURE_OPENAI_GPT4O_MINI_MODEL=
AZURE_OPENAI_EMBEDDING_MODEL=
MAX_TOKENS=4096
AZURE_DYNAMIC_SESSION_MGMT_ENDPOINT=
