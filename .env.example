OPENALEX_API_KEY=
OPENALEX_EMAIL=

# LiteLLM model IDs — change values here to switch providers, no code changes needed
LLM_SMART_MODEL=gemini/gemini-2.5-flash
LLM_FAST_MODEL=gemini/gemini-2.5-flash
LLM_VISION_MODEL=gemini/gemini-2.5-flash
LLM_VISION_FALLBACK_MODEL=openrouter/google/gemma-3-27b-it:free   # fallback on 429; leave empty to disable
LLM_EMBED_MODEL=gemini/gemini-embedding-001
LLM_RELEVANCE_EMBED_MODEL=ollama/nomic-embed-text   # Stage-1 relevance pre-screening; run via local Ollama
DISABLE_OLLAMA_THINK=false                          # set true for Ollama models with think mode (e.g. qwen3)

# Provider API keys — set whichever provider you use
GEMINI_API_KEY=          # get free key at aistudio.google.com
OPENROUTER_API_KEY=      # required if LLM_VISION_FALLBACK_MODEL uses openrouter/
MISTRAL_API_KEY=         # console.mistral.ai

MAX_TOKENS=4096

# Paper discovery tuning (optional — defaults shown)
PAPER_CANDIDATE_LIMIT=100         # max candidates fetched from OpenAlex
PAPER_CANDIDATE_MIN_CITATIONS=50  # minimum citation count filter
PAPER_CANDIDATE_YEAR_WINDOW=3     # publication recency window (years)
NUM_MAX_FINAL_PAPERS=5            # top-N papers to download after relevance filtering
ENABLE_QUERY_REFORMULATION=false  # set true to reformulate user query via LLM before OpenAlex search (step-back prompt)
SLIDE_GEN_MAX_RETRY_ATTEMPTS=3    # max consecutive run_code failures before agent is told to stop
